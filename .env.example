# ========================================
# Nuxt 博客系统环境变量模板
# 复制此文件为 `.env`，并填入真实的配置值
# 重要：本文件不应包含任何真实密钥
# ========================================

# ----------------------------
# MySQL 数据库连接（必须）
# ----------------------------
# 示例：mysql://root:password@127.0.0.1:3306/blog_system
DATABASE_URL=

# ----------------------------
# JWT（必须）
# ----------------------------
# 请使用强随机字符串（至少 32 位）
JWT_SECRET=

# ----------------------------
# 管理员初始化/重置保护（建议）
# ----------------------------
# 仅在 `NODE_ENV=production` 时生效：通过请求头 `x-admin-setup-token` 进行校验
# 若不配置，则生产环境会拒绝访问 `auth/init` 与 `auth/reset-admin`
ADMIN_SETUP_TOKEN=

# 可选：管理员注册提权口令（谨慎使用）
# 若未配置，则注册接口只会创建普通用户（role='user'）
ADMIN_SECRET_CODE=

# ========================================
# 阿里云 OSS 图片上传配置
# ========================================

# OSS 地域节点（例：oss-cn-hangzhou、oss-cn-shanghai、oss-cn-beijing）
# 查看地域列表：https://help.aliyun.com/zh/oss/user-guide/regions-and-endpoints
OSS_REGION=

# RAM 子账户 AccessKey ID（建议使用最小权限子账户，赋予 oss:PutObject 权限）
OSS_ACCESS_KEY_ID=

# RAM 子账户 AccessKey Secret
OSS_ACCESS_KEY_SECRET=

# OSS Bucket 名称
OSS_BUCKET=

# 自定义 CDN 域名（可选）
# 若绑定了自定义域名或 CDN，填入不含协议的域名，例：cdn.example.com
# 留空则使用 OSS 默认域名（格式：bucket.region.aliyuncs.com）
OSS_CUSTOM_DOMAIN=

# 上传文件存放目录前缀（可选，默认 blog/images）
OSS_UPLOAD_DIR=blog/images
